# Exclude things that should not enter the docker build context.
# The Dockerfile only needs source + third_party/{FBGEMM,FlexKV}; everything
# else is dev-only state that bloats context transfer to 14GB+.

# Workspace / IDE state
.codex
**/.codex
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.hypothesis
**/.mypy_cache
**/.ruff_cache

# Build / install artifacts.
# Scope to known build dirs only — pattern `**/build/` would also swallow
# third_party/FlexKV/csrc/dist/, fbgemm.../build/, etc. that are real headers /
# sources used by Dockerfile compile steps.
corelib/*/build/
corelib/*/_skbuild/
corelib/*/torch_binding_build/
examples/*/build/
examples/*/_skbuild/
examples/hstu/benchmark/build/
**/*.egg-info/

# Crash dumps from local pytest runs
core.pytest.*

# Local task / nsys logs (huge — 832MB on dev tree)
tasks/
examples/hstu/tasks/

# Local benchmark / profiling outputs
*.nsys-rep
*.qdrep
*.sqlite
nccl_timeline*.html
examples/hstu/profile/

# Local dev-only docker overlay templates
docker/Dockerfile.overlay-*
docker/patches/

# Git
.git/
.gitignore
.gitmodules
